# Rahat — environment configuration template.
#
# Copy this file to .env (gitignored) and fill in the values that apply.
# bootstrap.sh does the copy automatically on first run.
#
# .env is gitignored (and so is .env.bak.*), so values here never leave
# your machine. The .env.example file you're reading is the public
# contract: every key the runtime might read is documented here.

# ───────────────────────────── Required ─────────────────────────────

# Gemini API key (https://aistudio.google.com/apikey).
# Required for the live LLM path. The hermetic test stack runs without
# this — it stubs google.genai entirely (see tests/conftest.py).
GEMINI_API_KEY=

# Telegram bot token from @BotFather. Required to receive/send messages
# as the Sports Scientist; without it the agent prints to stdout.
SCIENTIST_BOT_TOKEN=

# Telegram chat id (your numeric user id, e.g. 123456789). Required for
# outbound — Miya only sends to this chat, never to anyone else.
TELEGRAM_CHAT_ID=

# ───────────────────────────── Tuning ───────────────────────────────

# Reasoner hop budget per turn. Limits the model-first tool-calling
# loop's depth. Default 6; lower if cost is a concern.
REASONER_HOP_BUDGET=6

# ───────────────────────────── Optional ─────────────────────────────

# Override the DB path. Leave unset for the default `vault/rahat.db`.
# RAHAT_TEST_MODE=1 always wins — it redirects to a per-process tempfile
# regardless of this setting (see core/io.py and the 2026-05-08 incident).
# RAHAT_DB_PATH=/custom/path/rahat.db

# Override the reasoner model id. Default chosen by core/io.py:llm_pick_flash_model.
# Examples: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash.
# RAHAT_REASONER_MODEL=gemini-2.5-flash

# Voice register override. Default uses the Hyderabadi/Dakhini voice
# layer; set to "neutral" to disable voice dressing (used by evals).
# RAHAT_VOICE=neutral

# Live eval opt-in. Set to 1 to allow tests/scientist/eval_reasoner_live.py
# to call Gemini for real. Off by default — costs money and is slow.
# RAHAT_EVAL_LIVE=0
