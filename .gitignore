essays/

# Rendered launchd plists — generated from *.plist.template by bootstrap.sh.
# The templates are tracked; the rendered files contain machine-specific
# absolute paths and must NEVER be committed.
core/com.rahat.miya.plist
bridges/sugarwod/com.rahat.sugar.bridge.plist
skills/com.rahat.vitals.plist
scripts/jobs/com.rahat.regression.plist
scripts/jobs/com.rahat.greenstreak.plist
scripts/jobs/com.rahat.hygiene.plist
scripts/jobs/com.rahat.evolve.plist

# PM working drafts — docx renders of PRDs/briefs. Markdown is the canonical text.
specs/*.docx
specs/Rahat_NextTen*
specs/Rahat_OrderAudit*
specs/Rahat_LifestyleWedge*

# Nightly status reports — auto-regenerated by launchd jobs.
NIGHTLY_*.md
NIGHTLY_*_STATUS.md

# Test runner artifact — regenerated on every `python -m tests.run_all`.
# Tracking it means every test run dirties the working tree (#36).
tests/last_run_report.md
