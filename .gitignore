vault/
# Genie household substrate — ROLE-based family Subjects + the family log.
# NEVER commit: contains household shape (and, in the real overlay, could
# carry PII). Covered by vault/ above; listed explicitly so the contract
# is discoverable and a future vault/ restructure can't silently expose it.
vault/family_profile.json
vault/genie_household.json
staging/
**/venv/
.DS_Store
*.db-shm
*.db-wal
__pycache__/
*.pyc
.env*
!.env.example
.pytest_cache/
pytest-cache-files-*/

# Private strategy / marketing / hire docs — NEVER commit these.
# Canonical home: rahat/private/ (gitignored folder, persists on disk, never committed).
CAMPAIGN_PLAN*.md
CAMPAIGN.md
RAHAT_CAMPAIGN*.md
*_KICKOFF_PROMPT.md
KICKOFF*.md
MARKETING*.md
STRATEGY*.md
HIRE*.md
POSITIONING*.md
BRAND_LINES.md
private/
.private/
rahat-strategy/
essays/

# Rendered launchd plists — generated from *.plist.template by bootstrap.sh.
# The templates are tracked; the rendered files contain machine-specific
# absolute paths and must NEVER be committed.
core/com.rahat.miya.plist
bridges/sugarwod/com.rahat.sugar.bridge.plist
skills/com.rahat.vitals.plist
scripts/jobs/com.rahat.regression.plist
scripts/jobs/com.rahat.greenstreak.plist
scripts/jobs/com.rahat.hygiene.plist
scripts/jobs/com.rahat.evolve.plist
scripts/com.rahat.miya.v2.plist

# PM working drafts — docx renders of PRDs/briefs. Markdown is the canonical text.
specs/*.docx
specs/Rahat_NextTen*
specs/Rahat_OrderAudit*
specs/Rahat_LifestyleWedge*

# Nightly status reports — auto-regenerated by launchd jobs.
NIGHTLY_*.md
NIGHTLY_*_STATUS.md

# Test runner artifact — regenerated on every `python -m tests.run_all`.
# Tracking it means every test run dirties the working tree (#36).
tests/last_run_report.md
tests/last_run_status.json

# Generated daily evangelist digests (scheduled task output) — artifacts,
# not source.
evangelist-digests/
compliance-digests/
.venv/

# Artifacts from unexpanded $HOME in env vars (e.g. cost_router.log
# landing in a literal $HOME directory). Defensive guard so a stray
# shell-expansion miss doesn't pollute the repo.
$HOME/

# Node.js — never commit installed deps; reproducible from package-lock.json.
node_modules/
**/node_modules/

# TypeScript build artifacts
**/dist/
**/*.tsbuildinfo

# IDE
.vscode/
.idea/
compliance-digests/

# internal working docs — keep local, never publish
specs/test_lead/findings/

# internal test-lead process docs — keep local
specs/test_lead/

# superseded internal archive — keep local
specs/archive/
